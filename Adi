<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anime_VEditor | Video Editing • UGC • Web Development • AI</title>
  <meta name="description" content="Anime_VEditor is a Gen-Z freelancer for video editing, UGC videos, website development, AI products, social media marketing, and graphic design." />
  <meta name="theme-color" content="#0a0a0f" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#0a0a0f; --bg2:#10111a; --card:rgba(255,255,255,.04); --border:rgba(255,255,255,.08);
      --text:#ffffff; --text2:#a0a0b4; --blue:#00d4ff; --pink:#ff2d95; --purple:#8b5cf6; --green:#00ff88;
      --shadow:0 20px 60px rgba(0,0,0,.35);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth;overflow-x:hidden}
    body{margin:0;font-family:Inter,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.6}
    a{color:inherit}
    img{max-width:100%;display:block}
    button,input,textarea{font:inherit}
    ::selection{background:rgba(0,212,255,.25)}

    .cursor{position:fixed;left:0;top:0;width:10px;height:10px;border-radius:50%;background:var(--blue);pointer-events:none;z-index:99998;box-shadow:0 0 18px var(--blue);transform:translate(-50%,-50%);transition:transform .08s ease,background .2s ease}
    .cursor-ring{position:fixed;left:0;top:0;width:38px;height:38px;border-radius:50%;border:1.5px solid rgba(0,212,255,.25);pointer-events:none;z-index:99997;transform:translate(-50%,-50%);transition:all .15s ease}
    .cursor.hover{background:var(--pink);transform:translate(-50%,-50%) scale(2.8)}
    .cursor-ring.hover{border-color:rgba(255,45,149,.35);transform:translate(-50%,-50%) scale(1.5)}

    .loader{position:fixed;inset:0;z-index:100000;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;transition:opacity .6s ease,visibility .6s ease}
    .loader.hidden{opacity:0;visibility:hidden}
    .loader-brand{font-family:'Space Grotesk',sans-serif;font-weight:800;font-size:2rem;background:linear-gradient(135deg,var(--blue),var(--pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
    .loader-bar{width:220px;height:3px;background:rgba(255,255,255,.08);border-radius:999px;overflow:hidden}
    .loader-fill{width:0;height:100%;background:linear-gradient(90deg,var(--blue),var(--pink));animation:load 1.7s ease forwards}
    .loader-sub{color:var(--text2);font-size:.85rem;letter-spacing:2px;text-transform:uppercase}
    @keyframes load{0%{width:0}65%{width:78%}100%{width:100%}}

    nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:16px 5%;display:flex;align-items:center;justify-content:space-between;background:rgba(10,10,15,.72);backdrop-filter:blur(18px);border-bottom:1px solid var(--border);transition:padding .3s ease,background .3s ease}
    nav.scrolled{padding:12px 5%;background:rgba(10,10,15,.92)}
    .brand{font-family:'Space Grotesk',sans-serif;font-size:1.2rem;font-weight:800;text-decoration:none;background:linear-gradient(135deg,var(--blue),var(--pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
    .nav-links{display:flex;align-items:center;gap:26px;list-style:none;margin:0;padding:0}
    .nav-links a{text-decoration:none;color:var(--text2);font-size:.92rem;font-weight:500;position:relative;transition:.25s}
    .nav-links a:hover{color:var(--text)}
    .nav-links a::after{content:'';position:absolute;left:0;bottom:-6px;width:0;height:2px;background:linear-gradient(90deg,var(--blue),var(--pink));transition:width .25s ease}
    .nav-links a:hover::after{width:100%}
    .nav-cta{padding:10px 18px;border-radius:999px;background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff !important;box-shadow:0 0 20px rgba(0,212,255,.2)}
    .nav-cta::after{display:none}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer}
    .hamburger span{width:24px;height:2px;background:#fff;transition:.25s}
    .hamburger.active span:nth-child(1){transform:translateY(7px) rotate(45deg)}
    .hamburger.active span:nth-child(2){opacity:0}
    .hamburger.active span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

    .hero{min-height:100vh;padding:120px 5% 80px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
    .hero::before,.hero::after{content:'';position:absolute;inset:-20%;pointer-events:none}
    .hero::before{background:radial-gradient(circle at 25% 35%,rgba(0,212,255,.12),transparent 30%),radial-gradient(circle at 75% 30%,rgba(255,45,149,.12),transparent 25%),radial-gradient(circle at 50% 75%,rgba(139,92,246,.12),transparent 30%);animation:bgSpin 28s linear infinite}
    .hero::after{background:linear-gradient(120deg,transparent,rgba(255,255,255,.03),transparent);transform:translateX(-35%)}
    @keyframes bgSpin{to{transform:rotate(360deg)}}
    .hero-inner{position:relative;z-index:1;max-width:980px;text-align:center}
    .pill{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--green);font-size:.84rem;margin-bottom:24px;backdrop-filter:blur(10px)}
    .dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 1.5s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
    h1{font-family:'Space Grotesk',sans-serif;font-size:clamp(2.2rem,6vw,4.6rem);line-height:1.06;margin:0 0 18px;font-weight:800;background:linear-gradient(135deg,#fff 0%,#9feaff 35%,#ffb6d7 70%,#ffffff 100%);background-size:200% 200%;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:shift 6s ease infinite}
    @keyframes shift{0%,100%{background-position:0 50%}50%{background-position:100% 50%}}
    .hero-sub{max-width:820px;margin:0 auto 34px;color:var(--text2);font-size:clamp(1rem,2vw,1.2rem)}
    .hero-sub strong{color:#fff}
    .hero-actions{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:24px}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;padding:15px 24px;border-radius:999px;border:1px solid transparent;text-decoration:none;font-weight:700;cursor:pointer;transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease,background .25s ease}
    .btn-primary{background:linear-gradient(135deg,var(--blue),var(--purple));color:#fff;box-shadow:0 18px 40px rgba(0,212,255,.18)}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 24px 52px rgba(0,212,255,.25)}
    .btn-secondary{background:rgba(255,255,255,.02);color:#fff;border-color:var(--border)}
    .btn-secondary:hover{transform:translateY(-2px);border-color:rgba(255,45,149,.6);box-shadow:0 16px 40px rgba(255,45,149,.12)}
    .trust{display:flex;justify-content:center;gap:18px;flex-wrap:wrap;color:var(--text2);font-size:.86rem}
    .trust span{display:inline-flex;align-items:center;gap:8px}
    .trust i{color:var(--green);font-style:normal}
    .scroll-hint{position:absolute;left:50%;bottom:28px;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--text2);font-size:.75rem;letter-spacing:2px;text-transform:uppercase;animation:bob 2s ease-in-out infinite}
    @keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}
    .scroll-line{width:1px;height:34px;background:linear-gradient(to bottom,var(--blue),transparent)}

    section{padding:96px 5%;position:relative}
    .section-head{text-align:center;max-width:760px;margin:0 auto 54px}
    .tag{display:inline-block;margin-bottom:12px;padding:6px 14px;border:1px solid var(--border);border-radius:999px;background:rgba(255,255,255,.04);color:var(--blue);font-size:.76rem;letter-spacing:2px;text-transform:uppercase}
    .title{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.8rem,3.2vw,2.8rem);line-height:1.1;margin:0 0 14px;font-weight:800}
    .title span{background:linear-gradient(135deg,var(--blue),var(--pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
    .subtitle{color:var(--text2);margin:0;font-size:1rem;line-height:1.7}

    .stats{background:var(--bg2)}
    .stats-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:18px;max-width:1100px;margin:0 auto}
    .stat{padding:28px 22px;border-radius:22px;background:rgba(255,255,255,.04);border:1px solid var(--border);text-align:center;box-shadow:var(--shadow);transition:transform .25s ease,border-color .25s ease}
    .stat:hover{transform:translateY(-4px);border-color:rgba(0,212,255,.35)}
    .stat-num{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:800;color:var(--blue);font-variant-numeric:tabular-nums}
    .stat-label{color:var(--text2);font-size:.82rem}

    .about-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:44px;align-items:center;max-width:1150px;margin:0 auto}
    .avatar-wrap{position:relative;width:min(100%,360px);aspect-ratio:1;margin:0 auto}
    .avatar-ring{position:absolute;inset:0;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--purple),var(--pink));padding:3px;animation:ring 8s linear infinite}
    @keyframes ring{to{filter:hue-rotate(360deg)}}
    .avatar-core{width:100%;height:100%;border-radius:50%;background:radial-gradient(circle at 30% 20%,rgba(255,255,255,.08),transparent 30%),var(--bg2);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
    .avatar-core::after{content:'';position:absolute;inset:0;background:radial-gradient(circle,rgba(0,212,255,.13),transparent 65%)}
    .avatar-core svg{width:42%;height:auto;z-index:1;opacity:.95}
    .about-text h3{font-family:'Space Grotesk',sans-serif;font-size:1.7rem;margin:0 0 14px;line-height:1.2}
    .about-text p{color:var(--text2);margin:0 0 18px;line-height:1.8}
    .skills{display:flex;flex-wrap:wrap;gap:10px}
    .skill{padding:9px 14px;border-radius:999px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:#dfe3ff;font-size:.84rem;transition:.25s}
    .skill:hover{transform:translateY(-2px);border-color:rgba(255,45,149,.45);color:#fff}

    .portfolio{background:var(--bg2)}
    .portfolio-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;max-width:1180px;margin:0 auto}
    .card{position:relative;border-radius:22px;overflow:hidden;min-height:280px;background:rgba(255,255,255,.04);border:1px solid var(--border);box-shadow:var(--shadow);transition:transform .25s ease,border-color .25s ease}
    .card:hover{transform:translateY(-6px);border-color:rgba(255,45,149,.35)}
    .thumb{position:absolute;inset:0}
    .thumb img{width:100%;height:100%;object-fit:cover;transition:transform .45s ease}
    .card:hover .thumb img{transform:scale(1.06)}
    .overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 42%,rgba(0,0,0,.9) 100%)}
    .play{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%) scale(0);width:64px;height:64px;border-radius:50%;background:rgba(0,212,255,.9);display:flex;align-items:center;justify-content:center;font-size:1.2rem;z-index:2;box-shadow:0 0 30px rgba(0,212,255,.35);transition:transform .35s ease}
    .card:hover .play{transform:translate(-50%,-50%) scale(1)}
    .meta{position:absolute;left:18px;right:18px;bottom:18px;z-index:3}
    .meta-top{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-bottom:8px}
    .meta-type{font-size:.78rem;color:var(--blue)}
    .meta-badge{font-size:.72rem;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid var(--border);color:#f7f8ff}
    .meta h4{font-family:'Space Grotesk',sans-serif;margin:0 0 4px;font-size:1.05rem}
    .meta p{margin:0;color:#99ffcc;font-size:.84rem;font-weight:600}
    .card .open-link{position:absolute;top:12px;right:12px;z-index:4;padding:7px 12px;border-radius:999px;background:rgba(255,45,149,.88);color:#fff;text-decoration:none;font-size:.74rem;font-weight:700;backdrop-filter:blur(10px)}
    .card .open-link.red{background:rgba(255,0,0,.88)}

    .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;max-width:1180px;margin:0 auto}
    .service{padding:28px 24px;border-radius:22px;background:rgba(255,255,255,.04);border:1px solid var(--border);box-shadow:var(--shadow);transition:transform .25s ease,border-color .25s ease}
    .service:hover{transform:translateY(-6px);border-color:rgba(0,212,255,.35)}
    .service .icon{width:54px;height:54px;border-radius:16px;background:linear-gradient(135deg,var(--blue),var(--purple));display:grid;place-items:center;font-size:1.3rem;margin-bottom:18px}
    .service h4{font-family:'Space Grotesk',sans-serif;font-size:1.08rem;margin:0 0 8px}
    .service p{margin:0 0 8px;color:var(--text2);font-size:.9rem;line-height:1.7}
    .result{margin-bottom:18px;color:#97ffce;font-size:.84rem;font-weight:600}
    .service a{color:var(--blue);text-decoration:none;font-weight:700;font-size:.9rem}

    .testimonials{background:var(--bg2)}
    .slider{max-width:860px;margin:0 auto;position:relative}
    .track{display:flex;transition:transform .5s cubic-bezier(.16,1,.3,1)}
    .slide{min-width:100%;padding:0 10px}
    .review{padding:34px 32px;border-radius:24px;background:rgba(255,255,255,.04);border:1px solid var(--border);box-shadow:var(--shadow);position:relative}
    .review::before{content:'“';position:absolute;left:22px;top:8px;font-family:serif;font-size:5rem;color:rgba(0,212,255,.15);line-height:1}
    .stars{color:#ffd54a;letter-spacing:2px;margin-bottom:16px}
    .review p{margin:0 0 24px;font-size:1.02rem;line-height:1.85;font-style:italic;color:#f5f7ff;position:relative;z-index:1}
    .author{display:flex;align-items:center;gap:14px}
    .avatar{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--pink));display:grid;place-items:center;font-weight:800}
    .author strong{display:block;font-size:.96rem}
    .author span{color:var(--text2);font-size:.82rem}
    .slider-controls{display:flex;justify-content:center;gap:12px;margin-top:22px}
    .nav-btn{width:44px;height:44px;border-radius:50%;border:1px solid var(--border);background:rgba(255,255,255,.04);color:#fff;cursor:pointer;display:grid;place-items:center;transition:.25s}
    .nav-btn:hover{background:var(--blue);border-color:var(--blue);box-shadow:0 0 18px rgba(0,212,255,.25)}
    .dots{display:flex;justify-content:center;gap:8px;margin-top:18px}
    .dot-btn{width:8px;height:8px;border:0;border-radius:50%;background:rgba(255,255,255,.18);cursor:pointer;transition:.25s}
    .dot-btn.active{width:26px;border-radius:999px;background:var(--blue);box-shadow:0 0 10px rgba(0,212,255,.3)}

    .why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;max-width:1180px;margin:0 auto}
    .why{padding:26px 22px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--border);text-align:center;box-shadow:var(--shadow);transition:.25s}
    .why:hover{transform:translateY(-5px);border-color:rgba(139,92,246,.45)}
    .why .icon{font-size:2rem;margin-bottom:10px;display:block}
    .why h4{margin:0 0 6px;font-family:'Space Grotesk',sans-serif;font-size:.98rem}
    .why p{margin:0;color:var(--text2);font-size:.84rem;line-height:1.65}

    .offer{padding-top:86px}
    .offer-box{max-width:780px;margin:0 auto;padding:44px 28px;border-radius:26px;background:linear-gradient(135deg,rgba(0,212,255,.06),rgba(255,45,149,.06));border:1px solid var(--border);box-shadow:var(--shadow);text-align:center;position:relative;overflow:hidden}
    .offer-box::before{content:'';position:absolute;inset:-30%;background:radial-gradient(circle,rgba(0,212,255,.05),transparent 55%);animation:bgSpin 20s linear infinite}
    .offer-box > *{position:relative;z-index:1}
    .urgency{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border-radius:999px;background:rgba(255,45,149,.1);border:1px solid rgba(255,45,149,.22);color:var(--pink);font-size:.78rem;font-weight:700;margin-bottom:14px}
    .offer-box h2{margin:0 0 10px;font-family:'Space Grotesk',sans-serif;font-size:clamp(1.6rem,3vw,2.5rem);line-height:1.1}
    .offer-box h2 span{background:linear-gradient(135deg,var(--blue),var(--pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
    .offer-box p{margin:0 0 24px;color:var(--text2)}

    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:1180px;margin:0 auto}
    .contact-info,.contact-form{padding:28px 24px;border-radius:22px;background:rgba(255,255,255,.04);border:1px solid var(--border);box-shadow:var(--shadow)}
    .contact-info h3{font-family:'Space Grotesk',sans-serif;font-size:1.45rem;margin:0 0 10px}
    .contact-info p{margin:0 0 18px;color:var(--text2)}
    .info-item{display:flex;align-items:center;gap:14px;padding:16px 18px;border-radius:16px;background:rgba(255,255,255,.03);border:1px solid var(--border);margin-bottom:14px;text-decoration:none;transition:.22s}
    .info-item:hover{transform:translateX(4px);border-color:rgba(0,212,255,.35)}
    .info-icon{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--blue),var(--purple));display:grid;place-items:center;flex:none}
    .info-label{font-size:.72rem;color:var(--text2);text-transform:uppercase;letter-spacing:1px}
    .info-value{font-size:.94rem;font-weight:600;text-decoration:none;color:#fff}

    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .field{margin-bottom:14px}
    .field label{display:block;margin:0 0 7px;color:var(--text2);font-size:.82rem}
    .field input,.field textarea{width:100%;padding:13px 14px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.02);color:#fff;outline:none;transition:.22s}
    .field input:focus,.field textarea:focus{border-color:rgba(0,212,255,.55);box-shadow:0 0 0 4px rgba(0,212,255,.08)}
    .field textarea{min-height:120px;resize:vertical}
    .submit{width:100%}

    .final{text-align:center;overflow:hidden}
    .final h2{font-family:'Space Grotesk',sans-serif;font-size:clamp(2rem,4vw,3rem);margin:0 0 12px}
    .final p{margin:0 0 28px;color:var(--text2)}

    footer{padding:50px 5% 24px;background:var(--bg2);border-top:1px solid var(--border)}
    .footer-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:28px}
    .footer-grid h4{font-family:'Space Grotesk',sans-serif;margin:0 0 14px}
    .footer-grid p,.footer-grid a{color:var(--text2);font-size:.9rem;text-decoration:none}
    .footer-grid a:hover{color:var(--blue)}
    .socials{display:flex;gap:10px;margin-top:16px}
    .social{width:42px;height:42px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.04);display:grid;place-items:center;text-decoration:none;color:#fff;transition:.22s}
    .social:hover{transform:translateY(-3px);border-color:rgba(255,45,149,.35);color:var(--pink)}
    .footer-bottom{text-align:center;margin-top:30px;padding-top:18px;border-top:1px solid var(--border);color:var(--text2);font-size:.82rem}

    .wa-float{position:fixed;right:24px;bottom:24px;z-index:9999}
    .wa-btn{width:58px;height:58px;border-radius:50%;display:grid;place-items:center;background:#25D366;color:#fff;text-decoration:none;box-shadow:0 18px 36px rgba(37,211,102,.35);animation:waPulse 2s ease-in-out infinite}
    .wa-tip{position:absolute;right:68px;top:50%;transform:translateY(-50%);background:#25D366;color:#fff;padding:7px 12px;border-radius:10px;font-size:.82rem;font-weight:700;white-space:nowrap;opacity:0;visibility:hidden;transition:.25s}
    .wa-float:hover .wa-tip{opacity:1;visibility:visible;right:74px}
    @keyframes waPulse{0%,100%{box-shadow:0 18px 36px rgba(37,211,102,.35)}50%{box-shadow:0 18px 40px rgba(37,211,102,.55)}}

    .modal{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;z-index:100001;padding:20px}
    .modal.active{display:flex}
    .modal-card{width:min(94vw,920px);background:var(--bg2);border:1px solid var(--border);border-radius:22px;overflow:hidden;box-shadow:var(--shadow);position:relative}
    .close{position:absolute;top:12px;right:12px;width:42px;height:42px;border-radius:50%;border:1px solid var(--border);background:rgba(255,255,255,.1);color:#fff;cursor:pointer;z-index:2}
    .modal-media{aspect-ratio:16/9;width:100%;background:#000}
    .modal-media iframe,.modal-media video{width:100%;height:100%;border:0;display:block}
    .modal-body{padding:18px 20px 22px}
    .modal-body h3{margin:0 0 8px;font-family:'Space Grotesk',sans-serif}
    .modal-body p{margin:0;color:var(--text2);line-height:1.7}
    .modal-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:16px}

    .reveal,.reveal-left,.reveal-right,.reveal-scale{opacity:0;transition:all .7s cubic-bezier(.16,1,.3,1)}
