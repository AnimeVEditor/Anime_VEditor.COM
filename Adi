    const modalIframe = document.getElementById('modalIframe');
    const modalTitle = document.getElementById('modalTitle');
    const modalDesc = document.getElementById('modalDesc');
    const cursor = document.getElementById('cursor');
    const cursorRing = document.getElementById('cursorRing');
    const testTrack = document.getElementById('testTrack');
    const sliderDots = document.getElementById('sliderDots');
    const reviewSlides = Array.from(document.querySelectorAll('.slide'));
    const cards = document.querySelectorAll('[data-animate-card]');

    let currentSlide = 0;
    let reviewTimer = null;
    let cursorX = window.innerWidth / 2;
    let cursorY = window.innerHeight / 2;
    let ringX = cursorX;
    let ringY = cursorY;

    function toggleNav(){
      navLinks.classList.toggle('open');
      ham.classList.toggle('active');
    }

    function closeNav(){
      navLinks.classList.remove('open');
      ham.classList.remove('active');
    }

    function openVideoModal(title, kind, desc, videoUrl){
      modalTitle.textContent = title;
      modalDesc.textContent = `${kind} • ${desc}`;
      modalIframe.src = videoUrl || 'https://www.youtube.com/embed/dQw4w9WgXcQ';
      modal.classList.add('active');
      modal.setAttribute('aria-hidden', 'false');
    }

    function closeVideoModal(){
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
      modalIframe.src = '';
    }

    function handleSubmit(e){
      e.preventDefault();
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();
      const text = `Hi Anime_VEditor,%0A%0AName: ${encodeURIComponent(name)}%0AEmail: ${encodeURIComponent(email)}%0AMessage: ${encodeURIComponent(message)}`;
      window.open(`https://wa.me/916289961371?text=${text}`, '_blank', 'noopener');
    }

    function slideTest(direction){
      currentSlide = (currentSlide + direction + reviewSlides.length) % reviewSlides.length;
      updateSlider();
      restartAutoSlide();
    }

    function updateSlider(){
      testTrack.style.transform = `translateX(-${currentSlide * 100}%)`;
      [...sliderDots.children].forEach((dot, idx) => dot.classList.toggle('active', idx === currentSlide));
    }

    function makeDots(){
      sliderDots.innerHTML = '';
      reviewSlides.forEach((_, idx) => {
        const d = document.createElement('button');
        d.className = 'dot-btn' + (idx === 0 ? ' active' : '');
        d.type = 'button';
        d.setAttribute('aria-label', `Go to review ${idx + 1}`);
        d.addEventListener('click', () => {
          currentSlide = idx;
          updateSlider();
          restartAutoSlide();
        });
        sliderDots.appendChild(d);
      });
    }

    function startAutoSlide(){
      reviewTimer = setInterval(() => slideTest(1), 5000);
    }

    function restartAutoSlide(){
      clearInterval(reviewTimer);
      startAutoSlide();
    }

    function setCounter(el, target){
      const duration = 1300;
      const start = performance.now();
      function tick(now){
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target);
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.classList.add('visible');
          if(entry.target.classList.contains('stats')){
            document.querySelectorAll('.stat-num').forEach(el => {
              if(!el.dataset.counted){
                el.dataset.counted = 'true';
                setCounter(el, Number(el.dataset.target || 0));
              }
            });
          }
        }
      });
    }, { threshold: 0.14 });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stat, .stats, .card, .service, .why, .slide, .section-head').forEach(el => revealObserver.observe(el));

    cards.forEach(card => {
      card.addEventListener('click', () => {
        openVideoModal(card.dataset.title, card.dataset.kind, card.dataset.desc, card.dataset.video);
      });
    });

    makeDots();
    updateSlider();
    startAutoSlide();

    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => loader.classList.add('hidden'), 700);
    });

    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 24);
    }, { passive: true });

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeVideoModal();
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeVideoModal();
    });

    const interactiveSelector = 'a, button, .card, .service, .why, .nav-links a, .hamburger';
    document.querySelectorAll(interactiveSelector).forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursor.classList.add('hover');
        cursorRing.classList.add('hover');
      });
      el.addEventListener('mouseleave', () => {
        cursor.classList.remove('hover');
        cursorRing.classList.remove('hover');
      });
    });

    window.addEventListener('mousemove', (e) => {
      cursorX = e.clientX;
      cursorY = e.clientY;
      cursor.style.left = cursorX + 'px';
      cursor.style.top = cursorY + 'px';
    });

    function animateRing(){
      ringX += (cursorX - ringX) * 0.12;
      ringY += (cursorY - ringY) * 0.12;
      cursorRing.style.left = ringX + 'px';
      cursorRing.style.top = ringY + 'px';
      requestAnimationFrame(animateRing);
    }
    animateRing();

    window.addEventListener('resize', () => {
      if(window.innerWidth > 760) closeNav();
    });

    // Close mobile nav when clicking a link.
    navLinks.addEventListener('click', (e) => {
      if (e.target.tagName === 'A' && window.innerWidth <= 760) closeNav();
    });
  </script>
</body>
</html>
